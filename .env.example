# Generic LLM config
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=

# Optional unified aliases
LLM_API_KEY=
LLM_BASE_URL=

# Optional DashScope-compatible config
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional web search
TAVILY_API_KEY=your_tavily_api_key

# Optional AMap Web Service APIs
AMAP_WEB_API_KEY=your_amap_web_api_key

# Optional Juhe stock API
JUHE_STOCK_API_KEY=your_juhe_stock_api_key

# Optional observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=ai-agent
